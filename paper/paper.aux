\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Cumulative wealth indexed to $1.0$ at March~2006. \emph  {Strategy (net)}: long-short portfolio after 10~bps per-side costs. \emph  {Strategy (gross)}: before costs. \emph  {US Market}: $\text  {Mkt-RF} + R_f$ from Ken French data library. \emph  {UMD}: Fama--French momentum factor. The strategy peaks at $\approx 1.6\times $ in mid-2008, collapses during the 2009 momentum crash, and declines through the subsequent bull market as the short leg persistently loses money.}}{8}{figure.1}\protected@file@percent }
\newlabel{fig:equity}{{1}{8}{Cumulative wealth indexed to $1.0$ at March~2006. \emph {Strategy (net)}: long-short portfolio after 10~bps per-side costs. \emph {Strategy (gross)}: before costs. \emph {US Market}: $\text {Mkt-RF} + R_f$ from Ken French data library. \emph {UMD}: Fama--French momentum factor. The strategy peaks at $\approx 1.6\times $ in mid-2008, collapses during the 2009 momentum crash, and declines through the subsequent bull market as the short leg persistently loses money}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Drawdown series for the net strategy (red) and the U.S.\ market (blue dashed), computed as the percentage decline from each series' running maximum. The strategy's $-81\%$ maximum drawdown reflects sequential crashes in 2009 and 2020 from which there was no meaningful recovery in between.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:dd}{{2}{8}{Drawdown series for the net strategy (red) and the U.S.\ market (blue dashed), computed as the percentage decline from each series' running maximum. The strategy's $-81\%$ maximum drawdown reflects sequential crashes in 2009 and 2020 from which there was no meaningful recovery in between}{figure.2}{}}
